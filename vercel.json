 {
     "version": 2,
     "buildCommand": "npm run build",
  "env": {
    "NODE_ENV": "production"
  },
     "builds": [
         {            
        "src": "dist/server.js",
         "use": "@vercel/node"
         }
     ],
     "routes": [
         {
         "src": "/(.*)",
         "dest": "dist/server.js"
         }
     ]
 }